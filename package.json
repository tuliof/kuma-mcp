{
  "name": "kuma-mcp",
  "version": "1.0.0",
  "description": "A MCP server for uptime-kuma v2",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kuma-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun run tsc --emitDeclarationOnly",
    "dev": "bun run src/index.ts",
    "test:unit": "bun test tests/unit/ --reporter=dots",
    "test:integration": "AGENT=1 ./scripts/test-with-docker.sh",
    "setup-kuma": "bun run scripts/setup-kuma-credentials.ts",
    "kuma:start": "docker compose up -d && bun run setup-kuma",
    "kuma:stop": "docker compose down --volumes",
    "preinspect": "bun run kuma:start",
    "inspect": "bunx @modelcontextprotocol/inspector bun run dev",
    "full-check": "biome check . && bun run build && bun run test:unit && bun run test:integration",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "uptime-kuma",
    "monitoring",
    "model-context-protocol"
  ],
  "author": "Tulio Fernandes",
  "license": "MIT",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.21.0",
    "socket.io-client": "^4.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/bun": "^1.3.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.2"
  }
}
